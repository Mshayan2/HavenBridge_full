# Backend environment variables (copy to .env and fill values)

PORT=5000
JWT_SECRET=change_me
FRONTEND_BASE_URL=http://localhost:5173

# MongoDB
# If your network blocks mongodb+srv (DNS TXT/SRV), you can enable in-memory DB for dev:
# MONGO_USE_MEMORY=true
# Otherwise set your real MongoDB URI:
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# Optional fallback to local Mongo
# MONGO_USE_FALLBACK=true
# MONGO_FALLBACK_URI=mongodb://127.0.0.1:27017/realestate

# Email (SMTP)
# MAIL_MODE= (empty) for normal, "silent" to disable, "debug" to allow debug links in production
MAIL_MODE=

# Gmail
SMTP_SERVICE=gmail
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_google_app_password_no_spaces
SMTP_SECURE=true
SMTP_FROM="HavenBridge <yourgmail@gmail.com>"

# (Alternative raw SMTP)
# SMTP_SERVICE=
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=smtp-user@example.com
# SMTP_PASS=supersecret
# SMTP_SECURE=false
# SMTP_FROM="HavenBridge <no-reply@example.com>"
